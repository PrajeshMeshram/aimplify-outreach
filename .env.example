# OpenRouter API key
# Get yours at: openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Models used per agent (do not change unless you want to experiment)
# Research agent  → google/gemini-2.0-flash-001  (best company knowledge, cheapest)
# Observer agent  → openai/gpt-4o-mini           (reliable JSON verification)
# Email agent     → anthropic/claude-haiku-4-5   (most human writing quality)

# App URL
NEXT_PUBLIC_APP_URL=https://b2b-outreach.vercel.app

# Google Sheets
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Gmail OAuth
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
GMAIL_USER=your_email@gmail.com
